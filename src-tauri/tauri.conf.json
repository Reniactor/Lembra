{
  "$schema": "https://raw.githubusercontent.com/nicedoc/json-schema/main/tauri-v2.json",
  "productName": "Lembra",
  "version": "0.1.1",
  "identifier": "com.lembra.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Reniactor/Lembra/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0OEQxQ0VDQjI5NjI2RTcKUldUbkpwYXk3QnlOSklucDZWUnprdnNLa2JuMDN0aExHK292a0syQ2ZiRWNPdHpHdG1KODNjeFQK"
    }
  }
}
